# ============================================================
# AST DevTools - Configuração de Ambiente
# ============================================================
# Copie este arquivo para .env e ajuste os valores conforme
# necessário para o seu ambiente local.
#
# Uso: docker-compose --env-file .env up
# ============================================================

# --- Timezone ---
# Timezone padrão da aplicação (afeta logs e timestamps do backend)
TZ=America/Sao_Paulo

# --- Frontend ---
FRONTEND_PORT=3000

# --- Backend ---
BACKEND_PORT=8080
